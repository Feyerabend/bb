10 REM Rainbow Color Cycle
20 CLS 0
30 TEXT 80, 10, "Color Cycle Demo", 65535
40 TEXT 60, 220, "Press Ctrl+C to stop", 2016
50 LET C = 0
60 REM Main loop
70 CLS 0
80 TEXT 80, 10, "Color Cycle Demo", 65535
90 FOR I = 0 TO 15
100 LET X = I * 20
110 LET COL = C + I * 4000
120 IF COL > 65535 THEN COL = COL - 65535
130 RECTF X, 50, 20, 140, COL
140 NEXT I
150 WAIT 100
160 LET C = C + 500
170 IF C > 65535 THEN C = 0
180 GOTO 70
