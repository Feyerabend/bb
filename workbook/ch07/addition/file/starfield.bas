10 REM Starfield Animation
20 CLS 0
30 TEXT 90, 10, "Starfield Demo", 65535
40 TEXT 60, 220, "Press Ctrl+C to stop", 2016
50 REM Initialize star positions
60 LET S1 = 50
70 LET S2 = 100
80 LET S3 = 150
90 LET S4 = 200
100 LET S5 = 250
110 REM Main animation loop
120 CLS 0
130 TEXT 90, 10, "Starfield Demo", 65535
140 REM Draw stars at different depths
150 PIXEL 80, S1, 65535
160 PIXEL 160, S2, 65535
170 PIXEL 240, S3, 65535
180 PIXEL 120, S4, 65535
190 PIXEL 200, S5, 65535
200 REM Draw medium stars
210 CIRCLEF 60, S1 + 20, 1, 63488
220 CIRCLEF 180, S2 + 30, 1, 63488
230 CIRCLEF 260, S3 + 40, 1, 63488
240 REM Draw large stars
250 CIRCLEF 100, S1 + 50, 2, 2016
260 CIRCLEF 220, S2 + 60, 2, 2016
270 WAIT 50
280 REM Move stars down
290 LET S1 = S1 + 2
300 LET S2 = S2 + 3
310 LET S3 = S3 + 4
320 LET S4 = S4 + 5
330 LET S5 = S5 + 6
340 REM Wrap around
350 IF S1 > 240 THEN S1 = 0
360 IF S2 > 240 THEN S2 = 0
370 IF S3 > 240 THEN S3 = 0
380 IF S4 > 240 THEN S4 = 0
390 IF S5 > 240 THEN S5 = 0
400 GOTO 120
