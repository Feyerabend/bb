10 REM Radar Sweep Animation
20 CLS 0
30 TEXT 100, 10, "Radar Sweep", 65535
40 TEXT 60, 220, "Press Ctrl+C to stop", 2016
50 LET A = 0
60 REM Main animation loop
70 CLS 0
80 TEXT 100, 10, "Radar Sweep", 2016
90 REM Draw radar circles
100 CIRCLE 160, 120, 30, 2016
110 CIRCLE 160, 120, 60, 2016
120 CIRCLE 160, 120, 90, 2016
130 REM Draw sweep line (approximated)
140 LET X1 = 160
150 LET Y1 = 120
160 LET X2 = 160 + A
170 LET Y2 = 120 - A
180 LINE X1, Y1, X2, Y2, 31
190 REM Draw some dots (targets)
200 CIRCLEF 200, 80, 3, 63488
210 CIRCLEF 120, 150, 3, 63488
220 CIRCLEF 180, 140, 3, 63488
230 WAIT 100
240 LET A = A + 5
250 IF A > 90 THEN A = 0
260 GOTO 70
